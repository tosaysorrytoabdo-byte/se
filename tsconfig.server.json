{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "declaration": false,
    "sourceMap": false,
    "jsx": "preserve",
    "lib": ["ES2022"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "target": "ES2022",
    "allowImportingTsExtensions": false
  },
  "include": ["api/**/*.ts", "bot/**/*.ts", "contracts/**/*.ts", "db/**/*.ts"],
  "exclude": ["node_modules", "dist", "src"]
}
