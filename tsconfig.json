{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "outDir": "dist",
    "rootDir": ".",
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "baseUrl": "."
  },
  "include": ["api/**/*.ts", "bot/**/*.ts", "db/**/*.ts", "contracts/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
